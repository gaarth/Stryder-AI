{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://stryder-ai.onrender.com/api/:path*"
        },
        {
            "source": "/health",
            "destination": "https://stryder-ai.onrender.com/health"
        },
        {
            "source": "/((?!assets).*)",
            "destination": "/index.html"
        }
    ]
}